# Git
abbr -a g git
abbr -a gst git status
abbr -a gch git checkout
abbr -a gd git diff
abbr -a gds git diff --staged
abbr -a gfm git pull
abbr -a gp git push

# GTS
abbr -a gts git status

# Tools
abbr -a h hx
abbr -a v hx
abbr -a y yazi
abbr -a zz zi
abbr -a zj zellij
abbr -a ll 'eza -lah --group-directories-first'
abbr -a la 'eza -a --group-directories-first'
abbr -a lt 'eza -aT --git-ignore --group-directories-first'
abbr -a l. 'eza -a | egrep "^\."'

# Extended Navigation
abbr -a .. cd ..
abbr -a ... cd ../../
abbr -a .... cd ../../../
abbr -a ..... 'cd ../../../../'
abbr -a ...... 'cd ../../../../../'
abbr -a ....... 'cd ../../../../../../'
