# Git
abbr -a gt git
abbr -a gts git status
abbr -a gtch git checkout
abbr -a gtd git diff
abbr -a gtds git diff --staged
abbr -a gtp git pull
abbr -a gtpu git push

# Tools
abbr -a h hx
abbr -a v hx
abbr -a y yazi
abbr -a zz zi
abbr -a zj zellij
abbr -a ll 'eza -lah --group-directories-first'
abbr -a la 'eza -a --group-directories-first'
abbr -a lt 'eza -aT --git-ignore --group-directories-first'
abbr -a l. 'eza -a | egrep "^\."'

# Extended Navigation
abbr -a .. cd ..
abbr -a ... cd ../../
abbr -a .... cd ../../../
abbr -a ..... 'cd ../../../../'
abbr -a ...... 'cd ../../../../../'
abbr -a ....... 'cd ../../../../../../'
