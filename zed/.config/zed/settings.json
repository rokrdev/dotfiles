// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "show_signature_help_after_edits": true,
  "code_lens": "on",
  "colorize_brackets": true,
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "auto_signature_help": false,
  "focus_follows_mouse": {
    "enabled": true,
  },
  "bottom_dock_layout": "contained",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "git_panel": {
    "file_icons": true,
    "tree_view": true,
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "status_bar": {
    "show_active_file": true,
  },
  "close_on_file_delete": true,
  "diff_view_style": "unified",
  "use_smartcase_search": true,
  "search": {
    "center_on_match": true,
    "regex": true,
    "include_ignored": false,
  },
  "helix_mode": true,
  "cli_default_open_behavior": "new_window",
  "autosave": "on_focus_change",
  "current_line_highlight": "all",
  "which_key": {
    "enabled": true,
  },
  "terminal": {
    "detect_venv": {
      "on": {
        "directories": [".env", "env", ".venv", "venv"],
        "activate_script": "default",
      },
    },
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "minimap": {
    "current_line_highlight": "all",
    "display_in": "all_editors",
    "show": "always",
  },
  "inlay_hints": {
    "enabled": false,
  },
  "vim": {
    "use_system_clipboard": "on_yank",
    "use_smartcase_find": false,
  },
  "project_panel": {
    "hide_hidden": false,
    "sticky_scroll": false,
    "hide_root": false,
    "git_status": true,
    "dock": "right",
    "git_status_indicator": false,
    "diagnostic_badges": false,
    "bold_folder_labels": false,
    "hide_gitignore": false,
  },
  "use_system_window_tabs": false,
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
  },
  "disable_ai": true,
  "agent": {
    "play_sound_when_agent_done": "always",
    "sidebar_side": "left",
  },
  "vim_mode": false,
  "buffer_font_family": "MonoLisa Nerd Font",
  "buffer_font_weight": 100,
  "buffer_font_size": 14,
  "ui_font_size": 16,
  "icon_theme": "Material Icon Theme",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Rosé Pine",
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
    "kotlin-lsp": {
      "binary": {
        "path": "/opt/homebrew/bin/kotlin-lsp",
        "arguments": ["--stdio"],
      },
      "settings": {
        "compiler": {
          "jvm": {
            "target": "21",
          },
        },
      },
    },
  },
  "languages": {
    "Kotlin": {
      "language_servers": ["kotlin-lsp"],
    },
  },
  "auto_install_extensions": {
    "github-theme": true,
    "material-icon-theme": true,
    "fish": true,
    "html": true,
    "kotlin": true,
    "lua": true,
    "python-snippets": true,
    "react-typescript-snippets": true,
    "toml": true,
    "typescript-snippets": true,
  },
  "context_servers": {
    "context-mode": {
      "command": "context-mode",
      "args": [],
      "env": {},
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "",
      },
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "serena",
        "serena-mcp",
        "--context",
        "ide-assistant",
        "--project-root",
        ".",
      ],
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
    },
  },
  "file_finder": {
    "file_icons": true,
    "modal_max_width": "medium",
    "skip_focus_for_active_in_search": true,
    "include_ignored": "smart",
    "include_channels": false,
  },
}
